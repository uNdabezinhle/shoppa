# Production deployment template (copy to .env.production for docker-compose.prod.yml)

SECRET_KEY=generate-a-long-random-secret
POSTGRES_PASSWORD=generate-a-strong-db-password
POSTGRES_USER=shoppa
POSTGRES_DB=shoppa

ALLOWED_HOSTS=api.shoppa.app
CORS_ALLOWED_ORIGINS=https://app.shoppa.app
API_PORT=8000
SHOPPA_RELEASE_VERSION=1.0.0

# Optional observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Stripe (live keys in production only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=https://app.shoppa.app/subscription/success
STRIPE_CHECKOUT_CANCEL_URL=https://app.shoppa.app/subscription/cancel