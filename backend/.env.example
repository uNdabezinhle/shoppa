# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# CORS (comma-separated origins for Flutter web / local dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis — Channels layer, Celery broker, and result backend (staging/prod).
# Omit for sqlite-only local dev: Channels uses in-memory, Celery runs eager.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Stripe (Phase 5 billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase Cloud Messaging (Phase 2+ / M8 push notifications)
FCM_SERVER_KEY=

# Typesense (M8 catalogue search). Leave empty to use DB icontains fallback.
TYPESENSE_HOST=
TYPESENSE_API_KEY=shoppa-dev-key

# Scraper (M8): seed | live. Live also requires SCRAPER_LIVE_ENABLED=true.
SCRAPER_MODE=seed
SCRAPER_LIVE_ENABLED=False

# Product verify / Open Food Facts (barcode food verification)
# OFF_CLIENT_MODE: live | fixture (fixture for CI / offline demos)
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=Shoppa/1.1 (product-verify; https://shoppa.app)
OFF_HTTP_TIMEOUT_SECONDS=1.5
OFF_CACHE_TTL_DAYS=7
OFF_NOT_FOUND_TTL_HOURS=24
OFF_CLIENT_MODE=live